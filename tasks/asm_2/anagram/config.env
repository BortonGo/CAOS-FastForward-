EJ_BAN_BY_REGEX_REQ_TEXT='\.text'
EJ_BAN_BY_REGEX_REQ_CALL_PUTS='\bcall getchar\b'
EJ_BAN_BY_REGEX_REQ_PROLOG='\b(pushq? %?rbp movq? %?rsp, %?rbp|pushq? rbp movq? rbp, rsp|pushq? rbp movq? rsp, rbp|enter \$?\d+, \$?\d+)\b'
EJ_BAN_BY_REGEX_REQ_EPILOG='\b(movq? %?rbp, %?rsp popq? %?rbp|movq? rsp, rbp popq? rbp|movq? rbp, rsp popq? rbp|leave|leaq? -\d+\(%rbp\), %rsp (popq? %r.. )+popq? %rbp)\b'
EJ_BAN_BY_REGEX_PREPROCESS='1'
EJ_BAN_BY_REGEX_IGNORE_CASE='1'
EJ_BAN_BY_REGEX_BAN_EXIT='call exit'
EJ_BAN_BY_REGEX_BAN_SORT='call \w*sort\w*'
